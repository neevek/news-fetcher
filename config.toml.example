# Configuration for the coding-agent news monitor.
#
# Copy this file to ~/.news-fetcher/config.toml (the default config location),
# or pass any path with --config.
#
# Each [[source]] entry is one place to fetch from. Supported `kind` values:
#   - "github_releases" : GitHub Releases API. `repo` = "owner/name".
#   - "hackernews"      : HN Algolia search. `query` = search string.
#   - "reddit"          : Subreddit JSON feed. `subreddit` = "ClaudeAI".
#   - "rss"             : Any RSS/Atom feed. `url` = feed URL.
#
# `always_relevant = true` keeps every item from that source (use for sources
# that are already topic-specific, like the Claude Code release feed).
# Otherwise items are kept only if they match one of the `keywords` below.

[settings]
# Items must contain at least one of these (case-insensitive) to be kept,
# unless their source is marked always_relevant.
keywords = [
  "claude code",
  "claude-code",
  "codex",
  "coding agent",
  "agentic coding",
  "ai coding",
  "anthropic",
  "openai",
]
# SQLite "seen items" store. A leading ~ is expanded to your home directory.
# Defaults to ~/.news-fetcher/news.db when omitted.
db_path = "~/.news-fetcher/news.db"
# Output: the static site is written under this directory (the GitHub Pages
# root). index.html is the latest day; feeds/yyyy/MM/dd.html are per-day pages.
output_dir = "docs"
# Custom domain for GitHub Pages. When set, a CNAME file is written into the
# output dir so Pages serves the site from this host.
custom_domain = "ainews.dob.cc"
# Summarizer (codex) settings. CLI --model / --thinking override these.
# thinking = reasoning effort: minimal | low | medium | high.
model = "gpt-5.3-codex"
thinking = "medium"

# ---- Official / high-signal sources ---------------------------------------

[[source]]
name = "Claude Code Releases"
kind = "github_releases"
repo = "anthropics/claude-code"
always_relevant = true

[[source]]
name = "Codex Releases"
kind = "github_releases"
repo = "openai/codex"
always_relevant = true

# ---- Community / buzz -------------------------------------------------------

[[source]]
name = "Hacker News: Claude Code"
kind = "hackernews"
query = "claude code"

[[source]]
name = "Hacker News: Codex"
kind = "hackernews"
query = "openai codex"

[[source]]
name = "Reddit r/ClaudeAI"
kind = "reddit"
subreddit = "ClaudeAI"

[[source]]
name = "Reddit r/OpenAI"
kind = "reddit"
subreddit = "OpenAI"

# ---- Example RSS source (uncomment / add your own) -------------------------

